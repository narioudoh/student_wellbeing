{
  "datasets": [
    {
      "name": "3870846e",
      "displayName": "Age Distubution",
      "queryLines": [
        "USE CATALOG `analysis`;\n",
        "USE SCHEMA `dev`;\n",
        "\n",
        "-- Age Group Distubtion --\n",
        "SELECT \n",
        "    CASE \n",
        "        WHEN Age < 20 THEN '<20'\n",
        "        WHEN Age BETWEEN 20 AND 25 THEN '20-25'\n",
        "        WHEN Age BETWEEN 26 AND 30 THEN '26-30'\n",
        "        ELSE '30+' \n",
        "    END AS age_group,\n",
        "    COUNT(*) AS count\n",
        "FROM student\n",
        "GROUP BY age_group;\n",
        "\n"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "5f8fba8b",
      "displayName": "Depression by Age_Group",
      "queryLines": [
        "USE CATALOG `analysis`;\n",
        "USE SCHEMA `dev`;\n",
        "\n",
        "-- Depression rate by age groupn --\n",
        "SELECT \n",
        "    CASE \n",
        "        WHEN Age < 20 THEN '<20'\n",
        "        WHEN Age BETWEEN 20 AND 25 THEN '20-25'\n",
        "        WHEN Age BETWEEN 26 AND 30 THEN '26-30'\n",
        "        ELSE '30+' \n",
        "   END AS age_group,\n",
        "    SUM(Depression) AS depressed_students,\n",
        "    COUNT(*) AS total,\n",
        "    (SUM(Depression) * 100 / COUNT(*)) AS depression_rate\n",
        "FROM student\n",
        "GROUP BY age_group;\n",
        "\n"
      ]
    },
    {
      "name": "a74419ef",
      "displayName": "Depression by Gender Based",
      "queryLines": [
        "USE CATALOG `analysis`;\n",
        "USE SCHEMA `dev`;\n",
        "\n",
        "-- Depression by Gender Based\n",
        "\n",
        "SELECT  \n",
        "  Gender, \n",
        "  sum(Depression) as Depressed_Individual,\n",
        "  count(*) as total,\n",
        "  (sum(Depression)*100 / count(*)) as Depression_rate\n",
        "from student\n",
        "group by Gender\n"
      ]
    },
    {
      "name": "8f3d1f1e",
      "displayName": "Academic_workload",
      "queryLines": [
        "SELECT \r\n",
        "    Academic_Pressure,\r\n",
        "    SUM(Depression) AS depressed,\r\n",
        "    COUNT(*) AS total,\r\n",
        "    (SUM(Depression) * 100.0 / COUNT(*)) AS depression_rate\r\n",
        "FROM student\r\n",
        "GROUP BY Academic_Pressure\r\n",
        "ORDER BY Academic_Pressure;\r\n"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "0a605bda",
      "displayName": "Degree_workload",
      "queryLines": [
        "SELECT\r\n",
        "  Academic_Pressure, Degree,\r\n",
        "  COUNT(CGPA) AS workload,\r\n",
        "  (sum(CGPA) * 100 / COUNT(*)) AS avg_workload\r\n",
        "FROM\r\n",
        "  student\r\n",
        "GROUP BY\r\n",
        "  Academic_Pressure, Degree\r\n",
        "ORDER BY\r\n",
        "  workload DESC"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "98f9ebeb",
      "displayName": "academic_pressure",
      "queryLines": [
        "SELECT\r\n",
        "    CASE\r\n",
        "        WHEN Academic_Pressure < 3 THEN 'Low'\r\n",
        "        WHEN Academic_Pressure BETWEEN 3 AND 6 THEN 'Medium'\r\n",
        "        ELSE 'High'\r\n",
        "    END AS academic_pressure_level,\r\n",
        "    Financial_Stress,\r\n",
        "    SUM(Depression) AS depressed_count,\r\n",
        "    COUNT(*) AS total_count,\r\n",
        "    (SUM(Depression) * 100.0 / COUNT(*)) AS depression_rate\r\n",
        "FROM analysis.dev.student\r\n",
        "GROUP BY academic_pressure_level, Financial_Stress\r\n",
        "ORDER BY depression_rate DESC"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "64a33caa",
      "displayName": "workstudy vs depression",
      "queryLines": [
        "SELECT \r\n",
        "    Work_Study_Hours,\r\n",
        "    SUM(Depression) AS depressed,\r\n",
        "    COUNT(*) AS total,\r\n",
        "    (SUM(Depression) * 100.0 / COUNT(*)) AS depression_rate\r\n",
        "FROM student\r\n",
        "GROUP BY Work_Study_Hours\r\n",
        "ORDER BY Work_Study_Hours;\r\n"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "82cf7857",
      "displayName": "sleep _vs_pressure",
      "queryLines": [
        "SELECT \r\n",
        "  Sleep_Duration,\r\n",
        "  Degree,\r\n",
        "  AVG(Academic_Pressure) AS avg_academic_pressure,\r\n",
        "  COUNT(*) AS student_count\r\n",
        "FROM analysis.dev.student\r\n",
        "GROUP BY Sleep_Duration, Degree\r\n",
        "ORDER BY avg_academic_pressure DESC"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "29e75bc2",
      "displayName": "suicidal",
      "queryLines": [
        "SELECT \r\n",
        "    Suicidal_Thoughts AS had_suicidal_thoughts,\r\n",
        "    SUM(\r\n",
        "        CASE \r\n",
        "            WHEN Suicidal_Thoughts = 'Yes' THEN 1 \r\n",
        "            ELSE 0 \r\n",
        "        END\r\n",
        "    ) AS Attempted_Suicide,\r\n",
        "    COUNT(*) AS total,\r\n",
        "    (\r\n",
        "        SUM(\r\n",
        "            CASE \r\n",
        "                WHEN Suicidal_Thoughts = 'Yes' THEN 1 \r\n",
        "                ELSE 0 \r\n",
        "            END\r\n",
        "        ) * 100.0\r\n",
        "        / count(suicidal_thoughts)\r\n",
        "    ) AS suicidal_rate\r\n",
        "FROM student\r\n",
        "GROUP BY Suicidal_Thoughts"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "01a90004",
      "displayName": "study_satisfaction",
      "queryLines": [
        "SELECT \r\n",
        "  Degree,\r\n",
        "  AVG(Study_Satisfaction) AS avg_study_satisfaction\r\n",
        "FROM student\r\n",
        "GROUP BY Degree\r\n",
        "ORDER BY avg_study_satisfaction DESC\r\n",
        "  "
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "a8fd7420",
      "displayName": "location_distrubution",
      "queryLines": [
        "SELECT City, COUNT(*) AS num_students\r\n",
        "FROM student\r\n",
        "GROUP BY City\r\n",
        "ORDER BY num_students DESC;"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "23c49063",
      "displayName": "gender count",
      "queryLines": [
        "SELECT COUNT(*) AS total_females\r\n",
        "FROM student\r\n",
        "WHERE gender = 'Female';\r\n",
        "\r\n",
        "\r\n",
        "SELECT COUNT(*) AS total_males\r\n",
        "FROM student\r\n",
        "WHERE gender = 'Male'\r\n",
        "\r\n",
        "\r\n",
        "\r\n",
        "\r\n"
      ],
      "catalog": "analysis",
      "schema": "dev"
    },
    {
      "name": "ca3c571c",
      "displayName": "cgpa_highest",
      "queryLines": [
        "SELECT CGPA\r\n",
        "FROM student\r\n",
        "ORDER BY CGPA DESC\r\n",
        "LIMIT 1;\r\n"
      ],
      "catalog": "analysis",
      "schema": "dev"
    }
  ],
