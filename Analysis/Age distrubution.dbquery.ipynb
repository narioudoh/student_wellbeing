   "source": [
    "-- Age Group Distubtion --\n",
    "SELECT \n",
    "    CASE \n",
    "        WHEN Age < 20 THEN '<20'\n",
    "        WHEN Age BETWEEN 20 AND 25 THEN '20-25'\n",
    "        WHEN Age BETWEEN 26 AND 30 THEN '26-30'\n",
    "        ELSE '30+' \n",
    "    END AS age_group,\n",
    "    COUNT(*) AS count\n",
    "FROM student\n",
    "GROUP BY age_group;\n",
    "\n"
   ]
  }
 ],
