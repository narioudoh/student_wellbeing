   "source": [
    "SELECT \n",
    "    Dietary_Habits,\n",
    "    --Sleep_Duration,\n",
    "    SUM(Depression) AS depressed,\n",
    "    COUNT(*) AS total,\n",
    "    (SUM(Depression) * 100.0 / COUNT(*)) AS depression_rate\n",
    "FROM student\n",
    "GROUP BY \n",
    "    Dietary_Habits\n",
    "   -- Sleep_Duration\n",
    "ORDER BY depression_rate DESC;"
   ]
  }
