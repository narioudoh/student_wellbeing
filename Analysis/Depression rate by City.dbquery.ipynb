   "source": [
    "-- depressin rate by city\n",
    "\n",
    "SELECT  \n",
    "  City, \n",
    "  sum(Depression) as Depressed_Individual,\n",
    "  count(*) as total,\n",
    "  (sum(Depression)*100 / count(*)) as Depression_rate\n",
    "from student\n",
    "group by City\n",
    "ORDER BY Depression_rate DESC\n"
   ]
  }
